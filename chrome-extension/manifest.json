{
  "manifest_version": 3,
  "name": "CV AI Builder - Capturador de Empleos",
  "version": "1.0",
  "description": "Guarda ofertas de trabajo de LinkedIn e InfoJobs directamente en tu tablero Kanban con un solo clic.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.infojobs.net/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.linkedin.com/jobs/view/*",
        "https://*.infojobs.net/*"
      ],
      "js": ["content.js"]
    }
  ]
}
